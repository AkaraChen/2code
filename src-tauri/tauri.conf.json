{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "center": true,
        "decorations": true,
        "height": 900,
        "hiddenTitle": true,
        "maximizable": true,
        "title": "code",
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        },
        "width": 1440
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "just build-helper \u0026\u0026 bun run build",
    "beforeDevCommand": "just build-helper-dev \u0026\u0026 bun run dev",
    "devUrl": "https://2code.localhost/",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/2code-helper"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "identifier": "com.akrc.code",
  "plugins": {
    "typegen": {
      "excludePatterns": null,
      "force": false,
      "includePatterns": null,
      "includePrivate": false,
      "outputPath": "./src/generated",
      "projectPath": "./src-tauri",
      "typeMappings": null,
      "validationLibrary": "none",
      "verbose": false,
      "visualizeDeps": false
    }
  },
  "productName": "two-code",
  "version": "1.4.2"
}
